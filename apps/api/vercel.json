{
  "installCommand": "cd ../.. && pnpm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ],
  "crons": [
    {
      "path": "/api/v1/internal/cron/subscriptions-daily-check",
      "schedule": "0 8 * * *"
    }
  ]
}
